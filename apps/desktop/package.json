{
	"name": "xernerx-app",
	"version": "1.1.31",
	"description": "Xernerx App",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"build": "npm i && tsc",
		"dist": "pnpm build && electron-builder",
		"dev": "tsc && electron .",
		"patch": "npm version patch",
		"minor": "npm version minor",
		"major": "npm version major"
	},
	"author": "Dummi",
	"license": "MIT",
	"packageManager": "pnpm@10.32.0",
	"dependencies": {
		"electron-store": "^11.0.2",
		"electron-updater": "^6.8.3"
	},
	"devDependencies": {
		"electron": "40.8.0",
		"electron-builder": "^26.8.1"
	},
	"build": {
		"nodeGypRebuild": false,
		"buildDependenciesFromSource": false,
		"asar": true,
		"npmRebuild": true,
		"appId": "com.xernerx.app",
		"productName": "Xernerx App",
		"icon": "public/icon.png",
		"compression": "maximum",
		"extraResources": [
			{
				"from": "metadata.json",
				"to": "metadata.json"
			}
		],
		"publish": [
			{
				"provider": "github",
				"owner": "Xernerx",
				"repo": "app",
				"releaseType": "release"
			}
		],
		"electronLanguages": [
			"en"
		],
		"directories": {
			"output": "release"
		},
		"win": {
			"target": "nsis",
			"artifactName": "${productName}-${version}-setup.${ext}"
		},
		"mac": {
			"target": "dmg",
			"artifactName": "${productName}-${version}-setup.${ext}"
		},
		"linux": {
			"target": "AppImage",
			"artifactName": "${productName}-${version}-setup.${ext}"
		},
		"nsis": {
			"oneClick": false,
			"differentialPackage": true,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true,
			"runAfterFinish": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "Xernerx App",
			"installerIcon": "public/icon.ico",
			"uninstallerIcon": "public/icon.ico",
			"installerSidebar": "public/banner.bmp",
			"uninstallerSidebar": "public/banner.bmp"
		}
	}
}
